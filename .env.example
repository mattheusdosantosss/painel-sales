# ---- HubSpot (tickets do pipeline Performance | MKT) ----
# Crie um Private App em Settings > Integrations > Private Apps
# Scopes de leitura necessários:
#   crm.objects.tickets.read   -> os tickets + os estágios do pipeline
#   crm.objects.owners.read    -> nome do "Proprietário do ticket"
#   (sem o owners.read, os tickets aparecem, mas o Proprietário fica como "—")
HUBSPOT_TOKEN=pat-na1-xxxxxxxx

# (opcional) sobrescrever o pipeline / áreas, caso mudem no HubSpot.
# Pipeline "Performance | MKT":
HUBSPOT_TICKETS_PIPELINE=794615341
# Áreas do solicitante incluídas (separadas por ";"):
HUBSPOT_AREAS=Comercial;Comercial | B2B;Comercial | B2C;Farmer | B2B;CS | B2B;CS | B2C

# ---- Login (admin + editor) ----
# AUTH_SECRET: chave aleatória p/ assinar a sessão (ex: openssl rand -hex 32).
# AUTH_ADMIN_HASH / AUTH_EDUARDO_HASH: hash "salt:key" da senha (scrypt).
# Gerar: node -e "const c=require('crypto');const s=c.randomBytes(16).toString('hex');console.log(s+':'+c.scryptSync(process.argv[1],s,64).toString('hex'))" "SUA_SENHA"
AUTH_SECRET=troque_por_32_bytes_hex
# admin (faz tudo) e editor (define prioridade)
AUTH_ADMIN_HASH=salt:key
AUTH_EDUARDO_HASH=salt:key
# viewers (logam e visualizam; não definem prioridade)
AUTH_NICOLLAS_HASH=salt:key
AUTH_LEANDRO_HASH=salt:key
AUTH_CESAR_HASH=salt:key
AUTH_DIEGO_HASH=salt:key

# OBS: editar prioridade grava no HubSpot (hs_ticket_priority + prioridade_de_demandas),
# então o token precisa do scope crm.objects.tickets.write.
